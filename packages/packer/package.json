    "mini-css-extract-plugin": "^2.10.2",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.1",
