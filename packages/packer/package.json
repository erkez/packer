{
  "name": "@ekz/packer",
  "version": "1.0.0-beta.5",
  "description": "Packer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./recommended": "./config/eslint/recommended.js",
    "./typescript": "./config/eslint/typescript.js",
    "./tsconfig/*": "./tsconfig/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/packer.git"
  },
  "homepage": "https://packer.ekz.io",
