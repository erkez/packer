{
    "extends": "./tsconfig/recommended.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "Node16",
        "moduleResolution": "Node16",
        "target": "ES2020",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
