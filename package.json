{
  "name": "packer-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "description": "Packer",
  "main": "src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/packer.git"
  },
  "scripts": {
    "build": "yarn workspace @ekz/packer build",
    "lint": "yarn workspace @ekz/packer lint && yarn workspace my-app lint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  }
}
